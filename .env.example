# Copy this file to `.env` (same directory) and fill in the values.
# `.env` is gitignored — never commit secrets.
#
# Phase 2 default backend is Gemini via Vertex AI (matches demo/config.json).
# You only need to fill in the GENAI section unless you switch backends.

# === Google Vertex AI / Gemini (REQUIRED for default Phase 2 setup) ===
GENAI_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=True

# === Azure OpenAI (only needed if you switch judge_model/backend to gpt-*) ===
AZURE_OPENAI_KEY=
AZURE_ENDPOINT=

# === Local vLLM server (only if you swap to vLLM Llama 3.3 70B) ===
VLLM_PORT=
